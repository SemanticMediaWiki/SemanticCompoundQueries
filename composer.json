{
	"name": "mediawiki/semantic-compound-queries",
	"type": "mediawiki-extension",
	"description": "A Semantic Mediawiki extension to display and combine multiple #ask queries in a single visualization output",
	"keywords": [
		"SMW",
		"Semantic MediaWiki",
		"Wiki",
		"MediaWiki"
	],
	"homepage": "https://www.mediawiki.org/wiki/Extension:Semantic_Compound_Queries",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Yaron Koren",
			"role": "Original author"
		}
	],
	"support": {
		"email": "semediawiki-user@lists.sourceforge.net",
		"issues": "https://github.com/SemanticMediaWiki/SemanticCompoundQueries/issues",
		"irc": "irc://irc.freenode.net/semantic-mediawiki",
		"forum": "https://www.semantic-mediawiki.org/wiki/semantic-mediawiki.org_talk:Community_portal",
		"wiki": "https://www.mediawiki.org/wiki/Extension:Semantic_Compound_Queries",
		"source": "https://github.com/SemanticCompoundQueries/SemanticCompoundQueries"
	},
	"require": {
		"php": ">=8.1",
		"composer/installers": "^2|^1.0.1"
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "43.0.0",
		"mediawiki/minus-x": "1.1.3",
		"php-parallel-lint/php-console-highlighter": "1.0.0",
		"php-parallel-lint/php-parallel-lint": "1.4.0"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "4.x-dev"
		}
	},
	"config": {
		"process-timeout": 0,
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"test": [
			"@analyze",
			"@phpunit"
		],
		"test-coverage": [
			"@analyze",
			"@phpunit-coverage"
		],
		"analyze": [
			"@lint",
			"@phpcs",
			"@minus-x"
		],
		"phpunit": "php ${MW_INSTALL_PATH:-../..}/tests/phpunit/phpunit.php -c phpunit.xml.dist",
		"phpunit-coverage": "php ${MW_INSTALL_PATH:-../..}/tests/phpunit/phpunit.php -c phpunit.xml.dist --testdox --coverage-text --coverage-html coverage/php --coverage-clover coverage/php/coverage.xml",
		"unit": "composer phpunit -- --testsuite semantic-compound-queries-unit",
		"integration": "composer phpunit -- --testsuite semantic-compound-queries-integration",
		"post-test-coverage": [
			"sed -i 's|/var/www/html/extensions/SemanticCompoundQueries/||g' coverage/php/coverage.xml",
			"find coverage/php -type f -name '*.html' -exec sed -i 's|/var/www/html/extensions/||g' {} +"
		],
		"phpcs": "phpcs -ps -d memory_limit=2G",
		"phpcs-fix": "phpcbf -p",
		"lint": "parallel-lint . --exclude vendor --exclude node_modules --exclude extensions",
		"minus-x": "minus-x check ."
	}
}
